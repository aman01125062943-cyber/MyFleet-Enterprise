# MyFleet Enterprise VPS environment
# Copy this file to /opt/myfleet-enterprise/deploy/vps/.env on the VPS.
# Keep the real .env on the VPS only. Do not commit it.

COMPOSE_PROJECT_NAME=myfleet_enterprise

# Public access
PUBLIC_APP_URL=https://your-myfleet-domain.example
APP_HOST_PORT=3012

# Frontend build/runtime Supabase endpoint.
# Current app code still uses Supabase APIs for auth, RLS, storage and data access.
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_SERVICE_KEY=replace-with-supabase-service-role-key

# Isolated local PostgreSQL database on this VPS.
# This is reserved for the local DB migration path and must not be shared.
POSTGRES_DB=myfleet_enterprise
POSTGRES_USER=myfleet_app
POSTGRES_PASSWORD=replace-with-strong-unique-password

# App service
NODE_ENV=production
PORT=3002
FRONTEND_URL=https://your-myfleet-domain.example
