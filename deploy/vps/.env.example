# MyFleet Enterprise isolated VPS environment
# Copy to /opt/myfleet-enterprise/deploy/vps/.env on the VPS only.
# Do not commit real values.

COMPOSE_PROJECT_NAME=myfleet_enterprise

# Temporary public access
VPS_PUBLIC_HOST=YOUR_VPS_IP_OR_HOST
APP_HOST_PORT=3012
SUPABASE_API_PORT=3013
FRONTEND_URL=http://YOUR_VPS_IP_OR_HOST:3012
VITE_SUPABASE_URL=http://YOUR_VPS_IP_OR_HOST:3013

# Local Supabase JWT settings.
# Generate JWT_SECRET as a long random string.
# ANON_KEY and SERVICE_ROLE_KEY must be JWTs signed with JWT_SECRET.
JWT_SECRET=replace-with-long-random-jwt-secret
JWT_EXPIRY=3600
ANON_KEY=replace-with-local-anon-jwt
SERVICE_ROLE_KEY=replace-with-local-service-role-jwt
SECRET_KEY_BASE=replace-with-64-plus-random-characters
REALTIME_DB_ENC_KEY=replace-with-16-random-characters

# Isolated local PostgreSQL database for this app only.
POSTGRES_DB=myfleet_enterprise
POSTGRES_PASSWORD=replace-with-strong-unique-password

# App service
NODE_ENV=production
PORT=3002

# Optional email settings. Autoconfirm is enabled for the temporary VPS phase.
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Storage
STORAGE_FILE_SIZE_LIMIT=52428800
